{
  "name": "clapshot-client",
  "private": true,
  "version": "0.9.0",
  "clapshot_min_server_version": "0.9.0",
  "clapshot_max_server_version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css-unused-selector:ignore,a11y-no-noninteractive-element-interactions:ignore,a11y-no-static-element-interactions:ignore\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tadashi/svelte-notification": "^1.3.0",
    "@tailwindcss/postcss": "^4.1.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.0.8",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.0.2",
    "postcss": "^8.5.2",
    "simple-drawing-board": "^3.1.2",
    "svelte": "^5.43.6",
    "svelte-check": "^4.3.4",
    "svelte-dnd-action": "^0.9.61",
    "svelte-file-dropzone": "^2.0.7",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.1.10",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^7.2.4",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "flowbite": "^4.0.0",
    "flowbite-svelte": "^1.28.0",
    "flowbite-svelte-icons": "^3.0.0"
  }
}
